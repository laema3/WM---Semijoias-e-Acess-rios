{
  "entities": {
    "product": {
      "title": "Product",
      "description": "A product in the store",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "cost_price": { "type": "number" },
        "stock": { "type": "integer" },
        "supplier": { "type": "string" },
        "image_url": { "type": "string" },
        "category": { "type": "string" },
        "category_id": { "type": "string" },
        "subcategory_id": { "type": "string" },
        "featured": { "type": "boolean" },
        "best_seller": { "type": "boolean" },
        "variations": { "type": "object", "description": "JSON object for variations like size/color" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category_id"]
    },
    "category": {
      "title": "Category",
      "description": "Product category",
      "type": "object",
      "properties": {
        "name": { "type": "string" }
      },
      "required": ["name"]
    },
    "subcategory": {
      "title": "Subcategory",
      "description": "Product subcategory",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category_id": { "type": "string" }
      },
      "required": ["name", "category_id"]
    },
    "settings": {
      "title": "Settings",
      "description": "Store settings",
      "type": "object",
      "properties": {
        "banner_title": { "type": "string" },
        "banner_image": { "type": "string" },
        "logo_url": { "type": "string" },
        "footer_address": { "type": "string" },
        "footer_phone": { "type": "string" },
        "footer_whatsapp": { "type": "string" },
        "footer_hours": { "type": "string" },
        "google_tag_id": { "type": "string" },
        "facebook_pixel_id": { "type": "string" },
        "me_token": { "type": "string" },
        "me_zip_origin": { "type": "string" },
        "me_sandbox": { "type": "string" },
        "mp_public_key": { "type": "string" },
        "mp_access_token": { "type": "string" }
      }
    },
    "user": {
      "title": "User",
      "description": "App user",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "customer"] }
      }
    }
  },
  "firestore": {
    "products/{productId}": {
      "schema": "product",
      "description": "Collection of products"
    },
    "categories/{categoryId}": {
      "schema": "category",
      "description": "Collection of categories"
    },
    "subcategories/{subcategoryId}": {
      "schema": "subcategory",
      "description": "Collection of subcategories"
    },
    "settings/global": {
      "schema": "settings",
      "description": "Global settings document"
    },
    "users/{userId}": {
      "schema": "user",
      "description": "User profiles"
    }
  }
}
